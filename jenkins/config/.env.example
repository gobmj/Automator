# SAP AI Core Credentials
# Copy this file to .env and fill in your actual credentials

# OAuth Client ID
AI_CORE_CLIENT_ID=your_client_id_here

# OAuth Client Secret
AI_CORE_CLIENT_SECRET=your_client_secret_here

# Authentication URL (OAuth token endpoint)
AI_CORE_AUTH_URL=https://your-tenant.authentication.region.hana.ondemand.com/oauth/token

# AI Core Base URL
AI_CORE_BASE_URL=https://api.ai.prod.region.aws.ml.hana.ondemand.com

# Deployment URL (includes deployment ID)
AI_CORE_DEPLOYMENT_URL=https://api.ai.prod.region.aws.ml.hana.ondemand.com/v2/inference/deployments/YOUR_DEPLOYMENT_ID/chat/completions

# Resource Group (usually 'default')
AI_CORE_RESOURCE_GROUP=default

# GitHub Personal Access Token (for webhook setup)
GITHUB_TOKEN=your_github_personal_access_token

# GitHub Repository
GITHUB_REPO=gobmj/Automator

# Jenkins URL (for webhook configuration)
JENKINS_URL=http://localhost:8080